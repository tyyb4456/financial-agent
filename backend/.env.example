# ── LLM Providers ─────────────────────────────────────────────────────────────
GOOGLE_API_KEY=your_google_api_key_here
GROQ_API_KEY=your_groq_api_key_here        # optional — only if using Groq

# ── External APIs ──────────────────────────────────────────────────────────────
SERPER_API_KEY=your_serper_api_key_here
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret

# ── LangSmith Tracing (optional — enables full node-by-node debugging) ────────
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=ai-workflows-api

# ── Checkpointing (pause/resume long runs) ──────────────────────────────────
CHECKPOINT_BACKEND=sqlite              # sqlite (default) | memory | redis
CHECKPOINT_SQLITE_PATH=./checkpoints.db
REDIS_URL=redis://localhost:6379        # only needed for CHECKPOINT_BACKEND=redis

# ── App ────────────────────────────────────────────────────────────────────────
PORT=8000
LOG_LEVEL=INFO
LOG_FORMAT=console                      # console (dev) | json (production)

ENVIRONMENT=development                 # development | staging | production
APP_VERSION=2.0.0

